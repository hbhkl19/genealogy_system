{
    "git.ignoreLimitWarning": true,
    "sqltools.connections": [
        {
            "ssh": "Disabled",
            "previewLimit": 50,
            "server": "localhost",
            "port": 5432,
            "driver": "PostgreSQL",
            "name": "Genealogy_Dev",
            "database": "genealogy_lab",
