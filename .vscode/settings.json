    "editor.formatOnSave": true,
    "terminal.integrated.inheritEnv": true,
    "terminal.integrated.env.windows": {
        "PATH": "${env:PATH};C:\\Program Files\\PostgreSQL\\16\\bin"
    },
    "files.exclude": {
        "**/__pycache__": true
    }
