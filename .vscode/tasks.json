{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Flask",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\flask.exe --app app run --debug",
      "problemMatcher": []
    },
    {
      "label": "Pytest",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m pytest",
      "problemMatcher": []
    },
    {
      "label": "Seed Data",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe scripts\\seed_data.py",
      "problemMatcher": []
    },
    {
      "label": "Import CSV",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe scripts\\import_csv.py --input-dir data\\generated",
      "problemMatcher": []
    },
    {
      "label": "DB Smoke Test",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe scripts\\db_smoke_test.py",
      "problemMatcher": []
    },
    {
      "label": "Explain Performance",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe scripts\\explain_performance.py --output docs\\performance_results.md",
      "problemMatcher": []
    },
    {
      "label": "Create Demo Data",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe scripts\\create_demo_data.py",
      "problemMatcher": []
    },
    {
      "label": "Export Branch",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe scripts\\export_branch.py",
      "problemMatcher": []
    }
  ]
}
